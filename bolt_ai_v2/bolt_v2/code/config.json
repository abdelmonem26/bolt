    "youtube_client_id": "\u2192 set YOUTUBE_CLIENT_ID in .env",
    "youtube_client_secret": "\u2192 set YOUTUBE_CLIENT_SECRET in .env",
    "youtube_refresh_token": "\u2192 set YOUTUBE_REFRESH_TOKEN in .env",
    "_tiktok_note": "TikTok API \u2014 FREE \u2014 developers.tiktok.com",
    "tiktok_access_token": "\u2192 set TIKTOK_ACCESS_TOKEN in .env",
    "_instagram_note": "Instagram Graph API \u2014 FREE \u2014 developers.facebook.com",
    "instagram_access_token": "\u2192 set INSTAGRAM_ACCESS_TOKEN in .env",
    "instagram_user_id": "\u2192 set INSTAGRAM_USER_ID in .env",
    "_notify": "Discord Webhook \u2014 FREE \u2014 Server Settings > Integrations > Webhooks",
    "discord_webhook_url": "\u2192 set DISCORD_WEBHOOK_URL in .env"
  },
  "platforms": {
    "youtube": {
      "enabled": true,
      "post_time": "14:00",
      "timezone": "America/New_York",
      "category_id": "28",
      "privacy": "public"
    },
    "tiktok": {
      "enabled": true,
      "post_time": "19:00",
      "timezone": "America/New_York"
    },
    "instagram": {
      "enabled": true,
      "post_time": "12:00",
      "timezone": "America/New_York"
    }
